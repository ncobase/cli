package features

import (
	"context"
	"fmt"
	"io"
	"net/url"
	"os"
	"path/filepath"
	"strings"
	"time"

	"github.com/ncobase/ncore/oss"
)

// StorageProvider defines the interface for storage backends.
type StorageProvider interface {
	Put(ctx context.Context, path string, reader io.Reader, size int64, contentType string) error
	Get(ctx context.Context, path string) (io.ReadCloser, error)
	Delete(ctx context.Context, path string) error
	Exists(ctx context.Context, path string) (bool, error)
	GetURL(ctx context.Context, path string) (string, error)
	GetSignedURL(ctx context.Context, path string, expiry time.Duration) (string, error)
	List(ctx context.Context, prefix string) ([]string, error)
	Copy(ctx context.Context, srcPath, dstPath string) error
	Move(ctx context.Context, srcPath, dstPath string) error
}

// LocalStorageProvider implements local filesystem storage.
type LocalStorageProvider struct {
	basePath string
	baseURL  string
}

// NewLocalStorageProvider creates a new local storage provider.
func NewLocalStorageProvider(basePath, baseURL string) *LocalStorageProvider {
	return &LocalStorageProvider{
		basePath: filepath.Clean(basePath),
		baseURL:  strings.TrimRight(baseURL, "/"),
	}
}

// Put uploads a file to local storage.
func (p *LocalStorageProvider) Put(ctx context.Context, path string, reader io.Reader, size int64, contentType string) error {
	target, err := p.safePath(path)
	if err != nil {
		return err
	}
	if err := os.MkdirAll(filepath.Dir(target), 0755); err != nil {
		return err
	}
	file, err := os.OpenFile(target, os.O_CREATE|os.O_WRONLY|os.O_TRUNC, 0644)
	if err != nil {
		return err
	}
	defer file.Close()
	if _, err := io.Copy(file, reader); err != nil {
		return err
	}
	return ctx.Err()
}

// Get retrieves a file from local storage.
func (p *LocalStorageProvider) Get(ctx context.Context, path string) (io.ReadCloser, error) {
	target, err := p.safePath(path)
	if err != nil {
		return nil, err
	}
	if err := ctx.Err(); err != nil {
		return nil, err
	}
	return os.Open(target)
}

// Delete removes a file from local storage.
func (p *LocalStorageProvider) Delete(ctx context.Context, path string) error {
	target, err := p.safePath(path)
	if err != nil {
		return err
	}
	if err := ctx.Err(); err != nil {
		return err
	}
	if err := os.Remove(target); err != nil && !os.IsNotExist(err) {
		return err
	}
	return nil
}

// Exists checks if a file exists in local storage.
func (p *LocalStorageProvider) Exists(ctx context.Context, path string) (bool, error) {
	target, err := p.safePath(path)
	if err != nil {
		return false, err
	}
	if err := ctx.Err(); err != nil {
		return false, err
	}
	_, err = os.Stat(target)
	if err == nil {
		return true, nil
	}
	if os.IsNotExist(err) {
		return false, nil
	}
	return false, err
}

// GetURL returns the public URL for a file.
func (p *LocalStorageProvider) GetURL(ctx context.Context, path string) (string, error) {
	if err := ctx.Err(); err != nil {
		return "", err
	}
	clean, err := cleanRelativePath(path)
	if err != nil {
		return "", err
	}
	if p.baseURL == "" {
		return clean, nil
	}
	return p.baseURL + "/" + url.PathEscape(clean), nil
}

// GetSignedURL returns a temporary URL for local storage deployments.
func (p *LocalStorageProvider) GetSignedURL(ctx context.Context, path string, expiry time.Duration) (string, error) {
	return p.GetURL(ctx, path)
}

// List lists files under a prefix.
func (p *LocalStorageProvider) List(ctx context.Context, prefix string) ([]string, error) {
	root, err := p.safePath(prefix)
	if err != nil {
		return nil, err
	}
	var files []string
	if err := filepath.WalkDir(root, func(path string, entry os.DirEntry, walkErr error) error {
		if walkErr != nil {
			return walkErr
		}
		if err := ctx.Err(); err != nil {
			return err
		}
		if entry.IsDir() {
			return nil
		}
		rel, err := filepath.Rel(p.basePath, path)
		if err != nil {
			return err
		}
		files = append(files, filepath.ToSlash(rel))
		return nil
	}); err != nil {
		if os.IsNotExist(err) {
			return files, nil
		}
		return nil, err
	}
	return files, nil
}

// Copy copies a file.
func (p *LocalStorageProvider) Copy(ctx context.Context, srcPath, dstPath string) error {
	src, err := p.Get(ctx, srcPath)
	if err != nil {
		return err
	}
	defer src.Close()
	return p.Put(ctx, dstPath, src, -1, "")
}

// Move moves a file.
func (p *LocalStorageProvider) Move(ctx context.Context, srcPath, dstPath string) error {
	if err := p.Copy(ctx, srcPath, dstPath); err != nil {
		return err
	}
	return p.Delete(ctx, srcPath)
}

func (p *LocalStorageProvider) safePath(path string) (string, error) {
	clean, err := cleanRelativePath(path)
	if err != nil {
		return "", err
	}
	target := filepath.Join(p.basePath, filepath.FromSlash(clean))
	if !strings.HasPrefix(target, p.basePath+string(os.PathSeparator)) && target != p.basePath {
		return "", fmt.Errorf("path escapes storage root")
	}
	return target, nil
}

func cleanRelativePath(path string) (string, error) {
	clean := filepath.ToSlash(filepath.Clean(strings.TrimSpace(path)))
	clean = strings.TrimPrefix(clean, "/")
	if clean == "." || clean == "" || strings.HasPrefix(clean, "../") || clean == ".." {
		return "", fmt.Errorf("invalid storage path")
	}
	return clean, nil
}

// OSSStorageProvider adapts ncore/oss storage to the local feature interface.
type OSSStorageProvider struct {
	storage oss.Interface
}

// NewOSSStorageProvider creates an object storage provider from ncore/oss config.
func NewOSSStorageProvider(cfg *oss.Config) (*OSSStorageProvider, error) {
	storage, err := oss.NewStorage(cfg)
	if err != nil {
		return nil, err
	}
	return &OSSStorageProvider{storage: storage}, nil
}

func (p *OSSStorageProvider) Put(ctx context.Context, path string, reader io.Reader, size int64, contentType string) error {
	if err := ctx.Err(); err != nil {
		return err
	}
	_, err := p.storage.Put(path, reader)
	return err
}

func (p *OSSStorageProvider) Get(ctx context.Context, path string) (io.ReadCloser, error) {
	if err := ctx.Err(); err != nil {
		return nil, err
	}
	return p.storage.Get(path)
}

func (p *OSSStorageProvider) Delete(ctx context.Context, path string) error {
	if err := ctx.Err(); err != nil {
		return err
	}
	return p.storage.Delete(path)
}

func (p *OSSStorageProvider) Exists(ctx context.Context, path string) (bool, error) {
	if err := ctx.Err(); err != nil {
		return false, err
	}
	return p.storage.Exists(path)
}

func (p *OSSStorageProvider) GetURL(ctx context.Context, path string) (string, error) {
	if err := ctx.Err(); err != nil {
		return "", err
	}
	return p.storage.GetURL(path)
}

func (p *OSSStorageProvider) GetSignedURL(ctx context.Context, path string, expiry time.Duration) (string, error) {
	return p.GetURL(ctx, path)
}

func (p *OSSStorageProvider) List(ctx context.Context, prefix string) ([]string, error) {
	if err := ctx.Err(); err != nil {
		return nil, err
	}
	objects, err := p.storage.List(prefix)
	if err != nil {
		return nil, err
	}
	paths := make([]string, 0, len(objects))
	for _, object := range objects {
		paths = append(paths, object.Path)
	}
	return paths, nil
}

func (p *OSSStorageProvider) Copy(ctx context.Context, srcPath, dstPath string) error {
	reader, err := p.Get(ctx, srcPath)
	if err != nil {
		return err
	}
	defer reader.Close()
	return p.Put(ctx, dstPath, reader, -1, "")
}

func (p *OSSStorageProvider) Move(ctx context.Context, srcPath, dstPath string) error {
	if err := p.Copy(ctx, srcPath, dstPath); err != nil {
		return err
	}
	return p.Delete(ctx, srcPath)
}

// StorageManager manages named storage providers.
type StorageManager struct {
	providers map[string]StorageProvider
	defaultName string
}

// NewStorageManager creates a new storage manager.
func NewStorageManager(defaultProvider string) *StorageManager {
	return &StorageManager{
		providers:   make(map[string]StorageProvider),
		defaultName: defaultProvider,
	}
}

// Register registers a storage provider.
func (m *StorageManager) Register(name string, provider StorageProvider) error {
	if strings.TrimSpace(name) == "" {
		return fmt.Errorf("storage provider name is required")
	}
	if provider == nil {
		return fmt.Errorf("storage provider %s is nil", name)
	}
	m.providers[name] = provider
	return nil
}

// Get returns a storage provider by name.
func (m *StorageManager) Get(name string) (StorageProvider, error) {
	if provider, ok := m.providers[name]; ok {
		return provider, nil
	}
	return nil, fmt.Errorf("storage provider %s not found", name)
}

// Default returns the default storage provider.
func (m *StorageManager) Default() (StorageProvider, error) {
	return m.Get(m.defaultName)
}
