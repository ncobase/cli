// MultiUploadHandler handles multiple file uploads
func MultiUploadHandler(config *UploadConfig) gin.HandlerFunc {
	if config == nil {
		config = DefaultUploadConfig()
	}

	return func(c *gin.Context) {
		ctx := c.Request.Context()

		// Parse multipart form
		if err := c.Request.ParseMultipartForm(config.MaxFileSize * 10); err != nil {
			logger.Errorf(ctx, "Failed to parse multipart form: %v", err)
			resp.Fail(c.Writer, resp.BadRequest("Failed to parse upload form"))
			return
		}

		form := c.Request.MultipartForm
		files := form.File["files"]

		if len(files) == 0 {
			resp.Fail(c.Writer, resp.BadRequest("No files uploaded"))
			return
		}

		uploadedFiles := make([]*FileInfo, 0, len(files))

		for _, header := range files {
			file, err := header.Open()
			if err != nil {
				logger.Errorf(ctx, "Failed to open file: %v", err)
				continue
			}

			// Validate and save file
			if header.Size <= config.MaxFileSize &&
				isAllowedType(header.Header.Get("Content-Type"), config.AllowedTypes) {

				fileInfo, err := saveFile(ctx, file, header, config)
				if err != nil {
					logger.Errorf(ctx, "Failed to save file %s: %v", header.Filename, err)
				} else {
					if userID, exists := c.Get("user_id"); exists {
						fileInfo.UploadedBy = userID.(string)
					}
					uploadedFiles = append(uploadedFiles, fileInfo)
				}
			}

			file.Close()
		}

		resp.Success(c.Writer, gin.H{
			"uploaded": len(uploadedFiles),
			"total":    len(files),
			"files":    uploadedFiles,
		})
	}
}

// DeleteFileHandler handles file deletion
func DeleteFileHandler(config *UploadConfig) gin.HandlerFunc {
	return func(c *gin.Context) {
		ctx := c.Request.Context()
		filePath := c.Param("path")

		if filePath == "" {
			resp.Fail(c.Writer, resp.BadRequest("File path required"))
			return
		}

		// Construct full path
		fullPath := filepath.Join(config.UploadPath, filePath)

		// Security check: ensure path is within upload directory
		if !strings.HasPrefix(fullPath, config.UploadPath) {
			resp.Fail(c.Writer, resp.Forbidden("Invalid file path"))
			return
		}

		// Delete file
		if err := os.Remove(fullPath); err != nil {
			if os.IsNotExist(err) {
				resp.Fail(c.Writer, resp.NotFound("File not found"))
			} else {
				logger.Errorf(ctx, "Failed to delete file: %v", err)
				resp.Fail(c.Writer, resp.InternalServerError("Failed to delete file"))
			}
			return
		}

		resp.Success(c.Writer, gin.H{"message": "File deleted successfully"})
	}
}
