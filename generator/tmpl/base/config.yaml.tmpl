# Application Configuration
appName: {{ .Name }}
environment: development
host: 0.0.0.0
port: 8080
domain: ""
timezone: UTC
locale: en

# Logger Configuration
logger:
  level: debug
  format: json  # json or text
  output: stdout  # stdout, stderr, or file path
  enableCaller: true
  enableStacktrace: false
  enableColor: false
  rotateMaxSize: 100  # MB
  rotateMaxBackups: 10
  rotateMaxAge: 30  # days
  rotateCompress: true

{{- if ne .DBDriver "none" }}

# Database Configuration
data:
  database:
    master:
      driver: {{ .DBDriver }}
{{- if eq .DBDriver "postgres" }}
      source: "host=localhost port=5432 user=postgres password=postgres dbname={{ .Name }} sslmode=disable TimeZone=UTC"
{{- else if eq .DBDriver "mysql" }}
      source: "root:password@tcp(localhost:3306)/{{ .Name }}?charset=utf8mb4&parseTime=True&loc=Local"
{{- else if eq .DBDriver "sqlite" }}
      source: "./data/{{ .Name }}.db"
{{- else }}
      source: "host=localhost port=5432 user=postgres password=postgres dbname={{ .Name }} sslmode=disable"
{{- end }}
      maxIdleConns: 10
      maxOpenConns: 100
      maxLifetime: 3600
      logging: true
      slowQueryThreshold: 200  # milliseconds

    # Slave/Read Replica Configuration (optional)
    # slaves:
    #   - driver: {{ .DBDriver }}
    #     source: "host=localhost port=5433 user=postgres password=postgres dbname={{ .Name }} sslmode=disable"
    #     maxIdleConns: 10
    #     maxOpenConns: 50
    #     maxLifetime: 3600

    migrate: true
    migrationTable: "schema_migrations"
{{- end }}

{{- if .UseRedis }}

  # Redis Configuration
  redis:
    - name: default
      addr: localhost:6379
      password: ""
      db: 0
      poolSize: 10
      minIdleConns: 5
      maxRetries: 3
      dialTimeout: 5  # seconds
      readTimeout: 3  # seconds
      writeTimeout: 3  # seconds
      poolTimeout: 4  # seconds
      idleTimeout: 300  # seconds

    # Redis Cluster Configuration (optional)
    # - name: cluster
    #   addrs:
    #     - localhost:7000
    #     - localhost:7001
    #     - localhost:7002
    #   password: ""
    #   poolSize: 10
{{- end }}

{{- if .UseElastic }}

  # Elasticsearch Configuration
  elasticsearch:
    addresses:
      - http://localhost:9200
    username: ""
    password: ""
    cloudID: ""
    apiKey: ""
    maxRetries: 3
    enableDebugLogger: false
{{- end }}

{{- if .UseMeili }}

  # MeiliSearch Configuration
  meilisearch:
    host: http://localhost:7700
    apiKey: ""
    timeout: 5  # seconds
{{- end }}

{{- if .UseOpenSearch }}

  # OpenSearch Configuration
  opensearch:
    addresses:
      - https://localhost:9200
    username: admin
    password: admin
    maxRetries: 3
    enableDebugLogger: false
{{- end }}

{{- if .UseKafka }}

  # Kafka Configuration
  kafka:
    brokers:
      - localhost:9092
    version: "2.8.0"
    clientID: {{ .Name }}
    groupID: {{ .Name }}-group
    saslEnable: false
    saslMechanism: PLAIN
    saslUsername: ""
    saslPassword: ""
    tlsEnable: false
{{- end }}

{{- if .UseRabbitMQ }}

  # RabbitMQ Configuration
  rabbitmq:
    url: amqp://guest:guest@localhost:5672/
    exchangeName: {{ .Name }}_exchange
    exchangeType: topic
    queueName: {{ .Name }}_queue
    routingKey: {{ .Name }}.#
    durable: true
    autoDelete: false
    prefetchCount: 10
{{- end }}

# Cache Configuration
cache:
  defaultTTL: 3600  # seconds
  cleanupInterval: 600  # seconds
{{- if .UseRedis }}
  driver: redis  # memory or redis
{{- else }}
  driver: memory
{{- end }}

# HTTP Server Configuration
server:
  readTimeout: 15  # seconds
  writeTimeout: 15  # seconds
  idleTimeout: 60  # seconds
  maxHeaderBytes: 1048576  # 1MB

  # CORS Configuration
  cors:
    enabled: true
    allowOrigins:
      - http://localhost:3000
      - http://localhost:8080
    allowMethods:
      - GET
      - POST
      - PUT
      - PATCH
      - DELETE
      - OPTIONS
    allowHeaders:
      - Origin
      - Content-Type
      - Authorization
      - X-Requested-With
    exposeHeaders:
      - Content-Length
    allowCredentials: true
    maxAge: 43200  # 12 hours

  # Rate Limiting
  rateLimit:
    enabled: true
    requests: 100
    window: 60  # seconds

  # Request Size Limits
  limits:
    maxRequestBodySize: 10485760  # 10MB
    maxMultipartMemory: 33554432  # 32MB

# Security Configuration
security:
  # JWT Configuration
  jwt:
    secret: "your-secret-key-change-in-production"
    issuer: {{ .Name }}
    expireTime: 86400  # 24 hours
    refreshExpireTime: 604800  # 7 days

  # Session Configuration
  session:
    name: session_id
    secret: "your-session-secret-change-in-production"
    maxAge: 86400  # 24 hours
    httpOnly: true
    secure: false  # set to true in production with HTTPS
    sameSite: lax  # strict, lax, or none

  # Password Configuration
  password:
    minLength: 8
    requireUppercase: true
    requireLowercase: true
    requireNumber: true
    requireSpecial: true
    bcryptCost: 12

# Observability Configuration
observability:
  # Tracing
  tracing:
    enabled: false
    endpoint: localhost:4318
    serviceName: {{ .Name }}
    sampleRate: 1.0

  # Metrics
  metrics:
    enabled: false
    endpoint: localhost:9090
    path: /metrics

  # Health Check
  health:
    enabled: true
    path: /health

# Feature Flags
features:
  enableSwagger: true
  enableMetrics: false
  enableTracing: false
  enableProfiling: false

