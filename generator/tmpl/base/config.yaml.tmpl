# Application name
app_name: {{ .Name }}
# Running environment: production / development / debug
environment: debug

server:
  # Protocol type: http / https
  protocol: http
  # Running domain
  domain: localhost
  # Application running address (localhost: 127.0.0.1, all addresses: 0.0.0.0)
  host: 127.0.0.1
  # Application running port
  port: 8080

{{- if .WithGRPC }}

grpc:
  enabled: true
  host: 127.0.0.1
  port: 9090
{{- end }}

{{- if ne .DBDriver "" }}

data:
  database:
    # Global configuration
    migrate: true  # migrate only support master
    strategy: random  # slave load balance strategy: round_robin / random
    max_retry: 3  # max retry
    # Master configuration
    master:
      driver: {{ .DBDriver }}
{{- if eq .DBDriver "postgres" }}
      source: postgres://postgres:postgres@localhost:5432/{{ .Name }}?sslmode=disable
{{- else if eq .DBDriver "mysql" }}
      source: root:password@tcp(localhost:3306)/{{ .Name }}?charset=utf8mb4&parseTime=True&loc=Local
{{- else if eq .DBDriver "sqlite" }}
      source: ./data/{{ .Name }}.db
{{- else if eq .DBDriver "mongodb" }}
      source: mongodb://localhost:27017/{{ .Name }}
{{- else }}
      source: localhost
{{- end }}
      max_open_conn: 32
      max_life_time: 7200
      max_idle_conn: 8
      logging: false
    # Slave configuration, support multiple (optional)
    # slaves:
    #   - driver: {{ .DBDriver }}
{{- if eq .DBDriver "postgres" }}
    #     source: postgres://postgres:postgres@localhost:5433/{{ .Name }}?sslmode=disable
{{- else if eq .DBDriver "mysql" }}
    #     source: root:password@tcp(localhost:3307)/{{ .Name }}?charset=utf8mb4&parseTime=True&loc=Local
{{- end }}
    #     max_open_conn: 64
    #     max_life_time: 7200
    #     max_idle_conn: 16
    #     logging: false
    #     width: 1
{{- end }}
{{- if .UseRedis }}
  redis:
    addr: localhost:6379
    password: ""
    db: 0
    read_timeout: 0.4s
    write_timeout: 0.6s
    dial_timeout: 1s
{{- end }}
{{- if .UseRabbitMQ }}
  rabbitmq:
    url: localhost:5672
    username: guest
    password: guest
    vhost: /
{{- end }}
{{- if .UseKafka }}
  kafka:
    brokers:
      - localhost:9092
    sasl:
      enable: false
      mechanism: ""
      username: ""
      password: ""
{{- end }}
{{- if or .UseElastic (or .UseMeili .UseOpenSearch) }}
  search:
{{- if .UseMeili }}
    meilisearch:
      host: http://localhost:7700
      api_key: ""
{{- end }}
{{- if .UseElastic }}
    elasticsearch:
      addresses:
        - http://localhost:9200
      username: ""
      password: ""
{{- end }}
{{- if .UseOpenSearch }}
    opensearch:
      addresses:
        - https://localhost:9200
      username: admin
      password: admin
{{- end }}
{{- end }}

auth:
  jwt:
    secret: "change-this-secret-in-production-use-openssl-rand-base64-32"
    expire: 48  # expiration time in hours
  whitelist:
    - /health
    - /login
    - /register
    - /logout
    - /captcha/*
    - /authorize/*
    - /token-status
    - /static/*
    - "*swagger*"

{{- if .WithTracing }}

observes:
  # OpenTelemetry tracing
  tracer:
    endpoint: localhost:4317  # OTLP gRPC endpoint
  # Sentry error tracking (optional)
  # sentry:
  #   endpoint: https://your-sentry-dsn@sentry.io/project-id
{{- end }}

logger:
  # Log level (1:fatal, 2:error, 3:warn, 4:info, 5:debug)
  level: 5
  # Log format (supported: text / json)
  format: text
  # Log output (supported: stdout / stderr / file / meilisearch / elasticsearch)
  output: stdout
  # Specify the file path for log output
  output_file: ./logs/runtime.log
{{- if .UseMeili }}
  meilisearch:
    host: http://localhost:7700
    api_key: ""
{{- end }}
{{- if .UseElastic }}
  # elasticsearch:
  #   addresses:
  #     - http://localhost:9200
  #   username: ""
  #   password: ""
{{- end }}

{{- if or .UseS3Storage (or .UseMinio .UseAliyun) }}

storage:
  # Provider: filesystem / minio / aliyun-oss / aws-s3 / azure / tencent-cos
{{- if .UseMinio }}
  provider: minio
  id: minioadmin
  secret: minioadmin
  bucket: {{ .Name }}
  endpoint: http://localhost:9000
{{- else if .UseAliyun }}
  provider: aliyun-oss
  id: ""  # AccessKey ID
  secret: ""  # AccessKey Secret
  region: oss-cn-hangzhou
  bucket: {{ .Name }}
  endpoint: oss-cn-hangzhou.aliyuncs.com
{{- else if .UseS3Storage }}
  provider: aws-s3
  id: ""  # AWS Access Key ID
  secret: ""  # AWS Secret Access Key
  region: us-east-1
  bucket: {{ .Name }}
  endpoint: ""  # Leave empty for AWS S3
{{- else }}
  provider: filesystem
  bucket: uploads  # Local storage path
  endpoint: ""
{{- end }}

  # Example: MinIO configuration
  # provider: minio
  # id: minioadmin
  # secret: minioadmin
  # bucket: {{ .Name }}
  # endpoint: http://localhost:9000

  # Example: Aliyun OSS configuration
  # provider: aliyun-oss
  # id: your-access-key-id
  # secret: your-access-key-secret
  # region: oss-cn-hangzhou
  # bucket: {{ .Name }}
  # endpoint: oss-cn-hangzhou.aliyuncs.com

  # Example: AWS S3 configuration
  # provider: aws-s3
  # id: your-access-key-id
  # secret: your-secret-access-key
  # region: us-east-1
  # bucket: {{ .Name }}
  # endpoint: ""

  # Example: Local filesystem storage
  # provider: filesystem
  # bucket: uploads
  # endpoint: ""
{{- end }}

