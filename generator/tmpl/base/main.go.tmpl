	"context"
	"errors"
	"flag"
	"fmt"
	"net"
	"net/http"
	"os"
	"os/signal"
	"strings"
	"syscall"
	"time"

	"{{ .PackagePath }}/internal/server"
	"{{ .PackagePath }}/internal/version"
	"github.com/ncobase/ncore/config"
	"github.com/ncobase/ncore/logging/logger"
	"github.com/ncobase/ncore/logging/observes"
{{- if .DBDriver }}
	_ "github.com/ncobase/ncore/data/{{ .DBDriver }}"
{{- end }}
{{- if .UseRedis }}
	_ "github.com/ncobase/ncore/data/redis"
{{- end }}
{{- if .UseElastic }}
	_ "github.com/ncobase/ncore/data/elasticsearch"
{{- end }}
{{- if .UseOpenSearch }}
	_ "github.com/ncobase/ncore/data/opensearch"
{{- end }}
{{- if .UseMeili }}
	_ "github.com/ncobase/ncore/data/meilisearch"
{{- end }}
{{- if .UseKafka }}
	_ "github.com/ncobase/ncore/data/kafka"
{{- end }}
{{- if .UseRabbitMQ }}
	_ "github.com/ncobase/ncore/data/rabbitmq"
{{- end }}
)

const (
	shutdownTimeout = 3 * time.Second
)

func main() {
	flag.Parse()
	version.Flags()

	conf := loadConfig()
	logger.SetVersion(version.GetVersionInfo().Version)

	appName := strings.ToLower(conf.AppName)

{{- if .WithTracing }}
	initTracer(conf, appName)
{{- end }}
	initSentry(conf, appName)

	cleanupLogger := initializeLogger(conf)
	defer cleanupLogger()

	logger.Infof(context.Background(), "Starting %s", appName)

	if err := runServer(conf); err != nil {
		logger.Fatalf(context.Background(), "Server error: %v", err)
	}
}

// runServer creates and runs HTTP{{- if .WithGRPC }} and gRPC{{- end }} server(s)
func runServer(conf *config.Config) error {
	// Create server
	s, err := server.New(conf)
	if err != nil {
		return fmt.Errorf("failed to create server: %w", err)
	}
	defer s.Cleanup()

	// Create listener
	listener, err := createListener(conf)
	if err != nil {
		return fmt.Errorf("failed to create listener: %w", err)
	}
	defer listener.Close()

	// Create HTTP server instance
	srv := &http.Server{
		Addr:         fmt.Sprintf("%s:%d", conf.Host, conf.Port),
		Handler:      s.Handler(),
		ReadTimeout:  15 * time.Second,
		WriteTimeout: 15 * time.Second,
		IdleTimeout:  60 * time.Second,
	}

	// Start HTTP server in goroutine
	errChan := make(chan error, 1)
	go func() {
		logger.Infof(context.Background(), "Listening and serving HTTP on: %s", srv.Addr)
		if err := srv.Serve(listener); err != nil && !errors.Is(err, http.ErrServerClosed) {
			errChan <- fmt.Errorf("HTTP server error: %w", err)
		}
	}()

{{- if .WithGRPC }}
	// Start gRPC server if available
	var grpcServer *server.GRPCServer
	if s.GRPCServer() != nil {
		grpcServer = s.GRPCServer()
		go func() {
			if err := grpcServer.Start(); err != nil {
				errChan <- fmt.Errorf("gRPC server error: %w", err)
			}
		}()
	}
{{- end }}

	return gracefulShutdown(srv{{- if .WithGRPC }}, grpcServer{{- end }}, errChan)
}

// createListener creates network listener
func createListener(conf *config.Config) (net.Listener, error) {
	addr := fmt.Sprintf("%s:%d", conf.Host, conf.Port)
	if conf.Port == 0 {
		addr = fmt.Sprintf("%s:0", conf.Host)
	}

	listener, err := net.Listen("tcp", addr)
	if err != nil {
		return nil, fmt.Errorf("failed to create listener: %w", err)
	}

	// Update port if dynamically allocated
	if conf.Port == 0 {
		conf.Port = listener.Addr().(*net.TCPAddr).Port
		logger.Infof(context.Background(), "Using dynamically allocated port: %d", conf.Port)
	}

	return listener, nil
}

// loadConfig loads the application configuration
func loadConfig() *config.Config {
	conf, err := config.Init()
	if err != nil {
		logger.Fatalf(context.Background(), "Failed to load config: %+v", err)
	}
	return conf
}

// initializeLogger initializes the logger
func initializeLogger(conf *config.Config) func() {
	cleanup, err := logger.New(conf.Logger)
	if err != nil {
		logger.Fatalf(context.Background(), "Failed to initialize logger: %+v", err)
	}
	return cleanup
}

// gracefulShutdown gracefully shuts down the server(s)
func gracefulShutdown(srv *http.Server{{- if .WithGRPC }}, grpcServer *server.GRPCServer{{- end }}, errChan chan error) error {
	quit := make(chan os.Signal, 1)
	signal.Notify(quit, syscall.SIGINT, syscall.SIGTERM)

	select {
	case err := <-errChan:
		return err

	case sig := <-quit:
		logger.Infof(context.Background(), "Received signal: %s, shutting down gracefully...", sig)

		ctx, cancel := context.WithTimeout(context.Background(), shutdownTimeout)
		defer cancel()

{{- if .WithGRPC }}
		// Stop gRPC server
		if grpcServer != nil {
			grpcServer.Stop()
		}
{{- end }}

		// Shutdown HTTP server
		if err := srv.Shutdown(ctx); err != nil {
			return fmt.Errorf("HTTP server forced to shutdown: %w", err)
		}

		logger.Info(context.Background(), "Server shutdown completed")
		return nil
	}
}

{{- if .WithTracing }}

func initTracer(conf *config.Config, appName string) {
	if conf.Observes == nil || conf.Observes.Tracer == nil {
		return
	}
	opt := &observes.TracerOption{
		URL:         conf.Observes.Tracer.Endpoint,
		Name:        appName,
		Version:     version.GetVersionInfo().Version,
		Environment: conf.Environment,
	}
	if err := observes.NewTracer(opt); err != nil {
		logger.Fatalf(context.Background(), "Failed to initialize tracer: %+v", err)
	}
}
{{- end }}

func initSentry(conf *config.Config, appName string) {
	if conf.Observes == nil || conf.Observes.Sentry == nil || conf.Observes.Sentry.Endpoint == "" {
		return
	}
	opt := &observes.SentryOptions{
		Dsn:         conf.Observes.Sentry.Endpoint,
		Name:        appName,
		Release:     version.GetVersionInfo().Version,
		Environment: conf.Environment,
	}
	if err := observes.NewSentry(opt); err != nil {
		logger.Fatalf(context.Background(), "Failed to initialize sentry: %+v", err)
	}
}
