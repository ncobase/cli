func setupTestRouter(h handler.Interface) *gin.Engine {
	gin.SetMode(gin.TestMode)
	router := gin.New()

	// Register routes
	v1 := router.Group("/api/v1")
	{
		v1.GET("/example", h.GetExample)
		// Add more routes as needed
	}

	return router
}

func TestGetExample(t *testing.T) {
	// Setup
	// Note: In production, use proper mocks for dependencies
	repo := repository.New(nil)
	svc := service.New(repo)
	h := handler.New(svc)
	router := setupTestRouter(h)

	t.Run("successful request", func(t *testing.T) {
		// Create request
		req := httptest.NewRequest(http.MethodGet, "/api/v1/example", nil)
		w := httptest.NewRecorder()

		// Execute
		router.ServeHTTP(w, req)

		// Assert
		assert.Equal(t, http.StatusOK, w.Code)

		// Parse response
		var response map[string]interface{}
		err := json.Unmarshal(w.Body.Bytes(), &response)
		require.NoError(t, err)

		// Verify response structure
		assert.Contains(t, response, "code")
		assert.Contains(t, response, "data")
	})

	t.Run("validation error", func(t *testing.T) {
		// Test validation scenarios
		req := httptest.NewRequest(http.MethodGet, "/api/v1/example?invalid=param", nil)
		w := httptest.NewRecorder()

		router.ServeHTTP(w, req)

		// Depending on your validation logic
		// assert.Equal(t, http.StatusBadRequest, w.Code)
	})
}

func TestCreateExample(t *testing.T) {
	repo := repository.New(nil)
	svc := service.New(repo)
	h := handler.New(svc)
	router := setupTestRouter(h)

	t.Run("successful creation", func(t *testing.T) {
		// Prepare request body
		requestBody := map[string]interface{}{
			"name": "Test Item",
			"code": "TEST001",
		}
		body, _ := json.Marshal(requestBody)

		// Create request
		req := httptest.NewRequest(http.MethodPost, "/api/v1/example", bytes.NewBuffer(body))
		req.Header.Set("Content-Type", "application/json")
		w := httptest.NewRecorder()

		// Execute
		router.ServeHTTP(w, req)

		// Assert
		assert.Equal(t, http.StatusOK, w.Code)

		var response map[string]interface{}
		err := json.Unmarshal(w.Body.Bytes(), &response)
		require.NoError(t, err)

		assert.Equal(t, 0, int(response["code"].(float64)))
	})

	t.Run("invalid request body", func(t *testing.T) {
		req := httptest.NewRequest(http.MethodPost, "/api/v1/example", bytes.NewBufferString("invalid json"))
		req.Header.Set("Content-Type", "application/json")
		w := httptest.NewRecorder()

		router.ServeHTTP(w, req)

		assert.Equal(t, http.StatusBadRequest, w.Code)
	})

	t.Run("missing required fields", func(t *testing.T) {
		requestBody := map[string]interface{}{
			"name": "", // Empty required field
		}
		body, _ := json.Marshal(requestBody)

		req := httptest.NewRequest(http.MethodPost, "/api/v1/example", bytes.NewBuffer(body))
		req.Header.Set("Content-Type", "application/json")
		w := httptest.NewRecorder()

		router.ServeHTTP(w, req)

		// assert.Equal(t, http.StatusBadRequest, w.Code)
	})
}

