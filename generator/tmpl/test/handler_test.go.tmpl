package tests

import (
	"context"
	"encoding/json"
	"net/http"
	"net/http/httptest"
	"testing"

	"github.com/gin-gonic/gin"
	"github.com/stretchr/testify/require"

	"{{ .PackagePath }}/data/model"
	"{{ .PackagePath }}/handler"
)

type fakeService struct{}

func (fakeService) GetExample(ctx context.Context) (*model.ExampleResponse, error) {
	return &model.ExampleResponse{ID: "example", Name: "Example Model"}, nil
}

func (fakeService) Close() error {
	return nil
}

func TestGetExample(t *testing.T) {
	gin.SetMode(gin.TestMode)
	router := gin.New()
	h := handler.New(fakeService{})
	router.GET("/api/v1/example", h.GetExample)

	req := httptest.NewRequest(http.MethodGet, "/api/v1/example", nil)
	res := httptest.NewRecorder()
	router.ServeHTTP(res, req)

	require.Equal(t, http.StatusOK, res.Code)

	var body struct {
		ID   string `json:"id"`
		Name string `json:"name"`
	}
	require.NoError(t, json.Unmarshal(res.Body.Bytes(), &body))
	require.Equal(t, "example", body.ID)
	require.Equal(t, "Example Model", body.Name)
}
