package tests

import (
	"context"
	"testing"
	"time"

	"github.com/stretchr/testify/require"

	"{{ .PackagePath }}/data/model"
	"{{ .PackagePath }}/service"
)

type fakeRepository struct {
	example *model.Example
}

func (r *fakeRepository) FindExample(ctx context.Context, id string) (*model.Example, error) {
	if r.example != nil {
		return r.example, nil
	}
	now := time.Now().UTC()
	return &model.Example{
		ID:        id,
		Name:      "Example Model",
		CreatedAt: now,
		UpdatedAt: now,
	}, nil
}

func TestServiceGetExample(t *testing.T) {
	svc := service.New(&fakeRepository{})
	defer func() {
		require.NoError(t, svc.Close())
	}()

	result, err := svc.GetExample(context.Background())
	require.NoError(t, err)
	require.Equal(t, "example", result.ID)
	require.Equal(t, "Example Model", result.Name)
}
